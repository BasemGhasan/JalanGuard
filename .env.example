# ============================================================
# JalanGuard Root Configuration — local environment
# Copy to .env and fill in. NEVER commit the real .env.
# ============================================================

# Supabase project URL for the JalanGuard platform
# Get it from Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Service-role key — REQUIRED for backend admin operations.
# Grants server-side permission to bypass RLS and manage data.
# Keep this server-side only; never expose to the client.
# Get it from Supabase Dashboard → Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anon key — REQUIRED for client-side authentication and public API access.
# Respects RLS policies. Safe to expose in the browser.
# Get it from Supabase Dashboard → Project Settings → API → anon public.
SUPABASE_ANON_KEY=your-anon-key-here

# Database connection URL for direct PostgreSQL access (optional).
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/jalanguard
