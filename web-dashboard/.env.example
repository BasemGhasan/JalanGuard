# ============================================================
# JalanGuard Web Dashboard — environment configuration
# Copy to .env and fill in. NEVER commit the real .env.
# ============================================================

# Supabase project URL — used by the frontend for real-time updates and auth.
# Get it from Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon key — public key for browser-side Supabase access.
# Respects RLS policies. Safe to expose in the frontend.
# Get it from Supabase Dashboard → Project Settings → API → anon public.
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# JalanGuard Open Data API base URL — backend endpoint for hazard queries.
# Local development: http://localhost:3000
# Production: https://your-api-domain.com or Google Cloud Run URL
VITE_API_BASE_URL=http://localhost:3000
