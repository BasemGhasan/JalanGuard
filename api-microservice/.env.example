# ============================================================
# JalanGuard Open Data API — backend environment
# Copy to .env and fill in. NEVER commit the real .env.
# ============================================================

# Supabase project (same project as the dashboard)
SUPABASE_URL=https://your-project-id.supabase.co

# Service-role key — REQUIRED. Grants the backend permission to call the
# service_role-only verify_api_key() RPC. Get it from:
#   Supabase Dashboard → Project Settings → API → service_role secret.
# This key bypasses RLS. Keep it server-side only; never ship it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated CORS origins allowed to call the API. "*" allows all.
CORS_ORIGINS=*

# Rate limit — requests per minute per API key.
RATE_LIMIT_PER_MINUTE=60

# Pagination bounds.
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100
